  "brand-runtime-fallbacks": {
    "_comment": "These are declared in :root and .dark as CSS aliases to --primary. AppShell.tsx overrides them at runtime for the active tenant. Declared in CSS so components referencing var(--brand-primary) before the JS effect fires get a valid default. NOTE: --ring and --accent-foreground are intentionally NOT in this list — AppShell.tsx does not currently inject them, so they remain static and do not follow merchant branding. See base.ring and brand.accent-foreground descriptions above.",
    "--brand-primary": { "light": "var(--primary)", "dark": "var(--primary)" },
    "--brand-primary-hover": {
      "light": "var(--primary)",
      "dark": "var(--primary)"
    },
    "--brand-foreground": {
      "light": "var(--primary-foreground)",
      "dark": "var(--primary-foreground)"
    },
    "--brand-tint": {
      "light": "oklch(0.6626 0.1296 240.2393 / 0.1)",
      "dark": "oklch(0.6595 0.1296 240.3010 / 0.1)"
    },
    "--brand-tint-hover": {
      "light": "oklch(0.6626 0.1296 240.2393 / 0.2)",
      "dark": "oklch(0.6595 0.1296 240.3010 / 0.2)"
    }
  },

